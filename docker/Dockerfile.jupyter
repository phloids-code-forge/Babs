FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    jupyter_client \
    ipykernel \
    jupyter-kernel-gateway \
    pandas \
    numpy \
    requests

EXPOSE 8888

ENTRYPOINT ["jupyter", "kernelgateway", "--KernelGatewayApp.ip=0.0.0.0", "--KernelGatewayApp.port=8888", "--KernelGatewayApp.auth_token=''", "--KernelGatewayApp.allow_origin='*'"]
