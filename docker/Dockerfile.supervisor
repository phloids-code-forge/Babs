FROM python:3.12-slim

WORKDIR /app

# Copy requirements and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy entire source tree (needed for imports)
COPY src/ /home/dave/babs/src/
COPY config/ /home/dave/babs/config/

# Set Python path to resolve imports
ENV PYTHONPATH=/home/dave/babs

# Run the supervisor
CMD ["python", "/home/dave/babs/src/supervisor/supervisor.py"]
