FROM avarok/dgx-vllm-nvfp4-kernel:v23

# Install vLLM 0.17.0rc0+cu130 aarch64 wheel (CUDA 13, ARM64, commit 097eb544)
# This is the cu130-native build that supports MIXED_PRECISION (Nemotron 3 Super)
RUN pip install -U "https://wheels.vllm.ai/097eb544e9a22810c9b7a59e586b61627b308362/vllm-0.17.0rc0%2Bcu130-cp38-abi3-manylinux_2_35_aarch64.whl"

# Pin flashinfer back to 0.6.3 -- the v23 base has precompiled SM_121a kernels for 0.6.3.
# 0.6.4 (pulled in by vLLM above) tries to JIT-compile SM_121a kernels at startup which
# OOM-kills nvcc on top of the 70GB model weights.
RUN pip install --no-deps "flashinfer-python==0.6.3"
